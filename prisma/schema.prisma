datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Logement {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  nom           String
  station       String
  prix_par_nuit Int
  capacite      Int
  type          String
  description   String?
  
  reservations  Reservation[]
}

model Client {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  nom_de_client    String
  prenom_de_client String
  email            String
  numero           Int
  age              String

  reservations     Reservation[]
}

model Reservation {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  logement_id String @db.ObjectId
  client_id   String @db.ObjectId
  logement    Logement @relation(fields: [logement_id], references: [id])
  client      Client   @relation(fields: [client_id], references: [id])
  start       String
  end         String
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
  nom      String
  prenom   String
}