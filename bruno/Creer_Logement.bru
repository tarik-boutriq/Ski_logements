  seq: 4
}

post {
  url: http://localhost:3001/logements
  body: json
  auth: bearer
}

auth:bearer {
  token: COLLE_TON_TOKEN_ICI
}

body:json {
  {
    "nom": "Chalet Mont Blanc",
